# ── SRI Command Center API — environment template ────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env.

# ── Google Drive ──────────────────────────────────────────────────────────────
# Path to your service-account credentials JSON downloaded from GCP console.
# The service account needs read access to the SRI Agent Platform Drive folder.
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/sri-service-account.json

# The Google Drive folder ID that is the root of the SRI Agent Platform.
# Find it in the Drive URL: drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_ROOT_FOLDER_ID=

# Subfolder inside the root where OS signal files live (default: signals)
DRIVE_SIGNALS_FOLDER_NAME=signals

# How often (seconds) to re-poll Drive for new signal files.
DRIVE_POLL_INTERVAL=30

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token (classic) or fine-grained token with:
#   repo:read, actions:read, pull_requests:read
GITHUB_TOKEN=

# Comma-separated list of org/repo slugs to watch for Builder OS projects.
# e.g.  sri-intel/command-center,sri-intel/marketing-engine
GITHUB_REPOS=

# GitHub org name (used for org-level queries)
GITHUB_ORG=sri-intel

# ── Server ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated allowed CORS origins (Vite dev server + any deployed frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Cache ─────────────────────────────────────────────────────────────────────
# In-memory TTL (seconds) for Drive and GitHub responses
CACHE_TTL=60
