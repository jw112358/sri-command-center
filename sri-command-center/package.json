{
  "name": "sri-command-center",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dev:api": "cd ../sri-command-center-api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:all": "concurrently --names UI,API --prefix-colors cyan,yellow \"npm run dev\" \"npm run dev:api\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.134.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.134.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^10.0.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
